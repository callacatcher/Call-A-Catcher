{
  "expo": {
    "name": "call-a-catcher",
    "slug": "call-a-catcher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/splash-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "2732x2732",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png", 
       "resizeMode": "1024x1024",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.callacatcher.callacatcher"
    },

   "web": {
  "favicon": "./assets/favicon.png",
  "name": "Call a Catcher",
  "shortName": "Catchers",
  "display": "standalone",
  "backgroundColor": "#ffffff",
  "themeColor": "#000000",
  "bundler": "metro",
  "meta": {
    "google-adsense-account": "ca-pub-3658953223794524"
  }
},

    "extra": {
      "eas": {
        "projectId": "aff17be6-f45f-473f-a720-5a8edf3d2a16"
      }
    },

    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },

    "plugins": [
      "expo-web-browser"
    ]
  }
}